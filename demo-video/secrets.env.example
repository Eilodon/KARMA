# Copy to secrets.env (gitignored) and fill in. Only the keystore password is secret;
# everything else lives in the repo .env. secrets.env is sourced by build.sh / record.sh.
#
#   cp demo-video/secrets.env.example demo-video/secrets.env
#   $EDITOR demo-video/secrets.env
#
KEYSTORE_PASSWORD=replace-with-the-real-keystore-password

# Optional overrides (defaults are sensible):
# TTS_VOICE=en-US-GuyNeural        # see: demo-video/.venv/bin/edge-tts --list-voices
# PHAROS_POLL_INTERVAL_MS=300      # snappier on-chain receipt polling for the recording
