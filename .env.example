# KARMA — example environment (copy to .env; .env is gitignored)
# Live-verified values recorded 2026-06-15 (scripts/check_connectivity.ts).

# ── KARMA Core ───────────────────────────────────────────────
NODE_ENV=development
TRANSPORT_DRIVER=http
HTTP_HOST=127.0.0.1
HTTP_PORT=3333
STORAGE_DRIVER=fs
MCP_PROJECT_ID=KARMA
MCP_TENANT_ID=tenant_local
TELEMETRY_DRIVER=stderr
MCP_AUTH_MODE=api_key
MCP_API_KEY=replace-with-at-least-32-char-random-string
ALLOWED_HOSTS=127.0.0.1:3333,localhost:3333
ALLOWED_ORIGINS=http://localhost:3333

# ── Plugin System — in-process trusted built-in (D-1/D-3) ────
# karma.tool.ts and t3.tool.ts run in-process (isTrustedBuiltInPlugin); external isolation
# is UNSUPPORTED for KARMA (per-call fork drops singletons + workerEnv() strips PHAROS_*/KEYSTORE_*).
MCP_SAFE_MODE=false
MCP_PLUGIN_ISOLATION_MODE=policy
MCP_PLUGIN_ALLOWLIST=system.tool.ts,karma.tool.ts,t3.tool.ts

# ── Terminal3 (T3ADK) ─────────────────────────────────────────
# Leave T3N_NODE_URL blank to use the SDK's built-in testnet URL.
# T3N_NODE_URL=

# ── Abuse Controls ───────────────────────────────────────────
ENABLE_RATE_LIMIT=true
RATE_LIMIT_MAX_REQUESTS=200
RATE_LIMIT_WINDOW_MS=60000

# ── Pharos Atlantic (LIVE-VERIFIED 2026-06-15) ───────────────
PHAROS_RPC_URL=https://atlantic.dplabs-internal.com
PHAROS_WSS_URL=wss://atlantic.dplabs-internal.com
PHAROS_CHAIN_ID=688689
PHAROS_CONTRACT_ADDRESS=0xReplaceAfterDeploy
PHAROS_EXPLORER=https://atlantic.pharosscan.xyz/
# Block to start the skill-event indexer backfill from (default 0 = full history).
KARMA_INDEXER_FROM_BLOCK=0

# ── Keystore (in-process only; never passed to a child worker) ──
KEYSTORE_PATH=./keystore.json
KEYSTORE_PASSWORD=replace-with-strong-password
